{% raw %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --red:#111111;
    --red-dark:#000000;
    --ink:#111111;
    --grey:#6b6b6b;
    --line:#e6e2dd;
    --cream:#F6F2EE;
    --white:#ffffff;
    --serif:'Lora',serif;
    --sans:'Poppins',sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  body{font-family:var(--sans);font-weight:300;font-size:15px;color:var(--ink);background:var(--white);line-height:1.6}
  img{display:block;max-width:100%}
  a{color:inherit;text-decoration:none}
  h1,h2,h3{font-family:var(--serif);font-weight:400;letter-spacing:.5px}
  .wrap{max-width:1280px;margin:0 auto;padding:0 24px}

  /* announcement bar */
  .announce{background:var(--red);color:#fff;font-size:12.5px;letter-spacing:1.2px;text-transform:uppercase;text-align:center;padding:9px 16px}

  /* header */
  header{position:sticky;top:0;background:var(--white);border-bottom:1px solid var(--line);z-index:50}
  .header-inner{display:flex;align-items:center;justify-content:space-between;padding:18px 24px;max-width:1280px;margin:0 auto}
  .logo img{height:42px}
  .icons{display:flex;gap:22px;font-size:13px;letter-spacing:.5px}
  .icons a{display:flex;align-items:center;gap:6px;color:var(--ink)}
  nav.main{border-top:1px solid var(--line)}
  .nav-list{display:flex;justify-content:center;gap:38px;list-style:none;max-width:1280px;margin:0 auto;padding:0 24px}
  .nav-list>li{position:relative}
  .nav-list>li>a{display:block;padding:14px 0;font-size:13.5px;letter-spacing:1.6px;text-transform:uppercase;font-weight:400;border-bottom:2px solid transparent}
  .nav-list>li>a:hover{border-bottom:2px solid var(--red);color:var(--red)}
  .nav-list>li>a.sale{color:var(--red);font-weight:500}
  /* mega menu */
  .mega{display:none;position:absolute;left:50%;transform:translateX(-50%);top:100%;background:var(--white);border:1px solid var(--line);box-shadow:0 14px 34px rgba(0,0,0,.09);padding:30px 40px;min-width:560px;z-index:60}
  .nav-list li:hover .mega{display:flex;gap:56px}
  .mega h4{font-size:12px;letter-spacing:2px;text-transform:uppercase;font-weight:600;margin-bottom:14px;color:var(--red)}
  .mega ul{list-style:none}
  .mega li a{display:block;padding:5px 0;font-size:14px;color:var(--grey)}
  .mega li a:hover{color:var(--ink)}

  /* hero */
  .hero{position:relative;background:var(--cream);overflow:hidden}
  .hero-grid{display:grid;grid-template-columns:1.05fr .95fr;min-height:560px;max-width:1280px;margin:0 auto}
  .hero-copy{display:flex;flex-direction:column;justify-content:center;padding:70px 60px 70px 24px}
  .hero-kicker{font-size:12px;letter-spacing:3px;text-transform:uppercase;color:var(--red);font-weight:500;margin-bottom:18px}
  .hero h1{font-size:52px;line-height:1.12;margin-bottom:20px}
  .hero p{font-size:16.5px;color:var(--grey);max-width:440px;margin-bottom:34px}
  .btn{display:inline-block;padding:15px 38px;border:1px solid var(--ink);font-size:13px;letter-spacing:2px;text-transform:uppercase;font-weight:400;transition:.25s;background:transparent;cursor:pointer}
  .btn:hover{background:var(--ink);color:#fff}
  .btn-solid{background:var(--ink);color:#fff}
  .btn-solid:hover{background:var(--red);border-color:var(--red)}
  .btn-red{background:var(--red);border-color:var(--red);color:#fff}
  .btn-red:hover{background:var(--red-dark);border-color:var(--red-dark)}
  .hero-media{position:relative}
  .hero-media img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0}

  /* section headings */
  .section{padding:80px 0}
  .section-head{text-align:center;margin-bottom:44px}
  .section-head h2{font-size:34px;margin-bottom:8px}
  .section-head p{color:var(--grey);font-size:15px}

  /* trio category tiles */
  .trio{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
  .tile{position:relative;overflow:hidden;aspect-ratio:4/5;background:var(--cream)}
  .tile img{width:100%;height:100%;object-fit:cover;transition:transform .6s}
  .tile:hover img{transform:scale(1.05)}
  .tile-label{position:absolute;left:0;right:0;bottom:0;padding:80px 28px 28px;background:linear-gradient(transparent,rgba(0,0,0,.55));color:#fff}
  .tile-label h3{font-size:26px;margin-bottom:4px}
  .tile-label span{font-size:12.5px;letter-spacing:2px;text-transform:uppercase;border-bottom:1px solid #fff;padding-bottom:2px}

  /* collection grid */
  .coll-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
  .coll{position:relative;aspect-ratio:1/1;overflow:hidden;background:var(--cream);display:flex;align-items:flex-end}
  .coll img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform .6s}
  .coll:hover img{transform:scale(1.06)}
  .coll span{position:relative;z-index:2;width:100%;text-align:center;background:rgba(255,255,255,.92);padding:12px 8px;font-size:13px;letter-spacing:1.8px;text-transform:uppercase}
  .coll.plain{align-items:center;justify-content:center}
  .coll.plain span{background:none;font-family:var(--serif);font-size:20px;text-transform:none;letter-spacing:.5px}

  /* product cards */
  .prod-row{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
  .card{background:#fff}
  .card-img{position:relative;aspect-ratio:1/1;background:var(--cream);overflow:hidden}
  .card-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s}
  .card:hover .card-img img{transform:scale(1.04)}
  .tag{position:absolute;top:12px;left:12px;background:var(--red);color:#fff;font-size:10.5px;letter-spacing:1.5px;text-transform:uppercase;padding:4px 10px;font-weight:500}
  .quick{position:absolute;left:0;right:0;bottom:-48px;background:var(--ink);color:#fff;text-align:center;padding:12px;font-size:12px;letter-spacing:2px;text-transform:uppercase;transition:bottom .3s;cursor:pointer}
  .card:hover .quick{bottom:0}
  .card-info{padding:16px 4px}
  .card-info .type{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--grey);margin-bottom:4px}
  .card-info .name{font-size:15px;font-weight:400;margin-bottom:6px}
  .card-info .price{font-size:15px;font-weight:500}

  /* banner strip */
  .banner{background:var(--ink);color:#fff;text-align:center;padding:90px 24px}
  .banner h2{font-size:38px;margin-bottom:12px}
  .banner p{color:#cfc9c2;max-width:560px;margin:0 auto 30px}
  .banner .chips{display:flex;flex-wrap:wrap;gap:12px;justify-content:center;margin-bottom:34px}
  .chip{border:1px solid rgba(255,255,255,.35);padding:8px 20px;font-size:12.5px;letter-spacing:2px;text-transform:uppercase;transition:.25s}
  .chip:hover{background:#fff;color:var(--ink)}
  .banner .btn{border-color:#fff;color:#fff}
  .banner .btn:hover{background:#fff;color:var(--ink)}

  /* promo tiers */
  .promo{background:var(--cream)}
  .tiers{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;max-width:900px;margin:0 auto}
  .tier{background:#fff;border:1px solid var(--line);text-align:center;padding:36px 20px}
  .tier.best{border:2px solid var(--red)}
  .tier .t-label{font-size:11px;letter-spacing:2.5px;text-transform:uppercase;color:var(--grey);margin-bottom:10px}
  .tier h3{font-size:24px;margin-bottom:6px}
  .tier .back{font-family:var(--serif);font-size:30px;color:var(--red)}
  .tier .gift{font-size:12.5px;letter-spacing:1.5px;text-transform:uppercase;margin-top:8px;font-weight:500}

  /* newsletter */
  .news{background:var(--cream);text-align:center;padding:76px 24px}
  .news h2{font-size:30px;margin-bottom:10px}
  .news p{color:var(--grey);max-width:480px;margin:0 auto 28px}
  .news form{display:flex;max-width:460px;margin:0 auto}
  .news input{flex:1;padding:14px 18px;border:1px solid var(--ink);border-right:none;font-family:var(--sans);font-size:14px;background:#fff;outline:none}
  .news button{padding:14px 30px;background:var(--ink);color:#fff;border:1px solid var(--ink);font-size:12.5px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;font-family:var(--sans)}
  .news button:hover{background:var(--red);border-color:var(--red)}

  /* footer */
  footer{background:#111;color:#d8d2cb;padding:70px 0 0;font-size:14px}
  .foot-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1.3fr;gap:50px;padding-bottom:50px}
  footer h4{color:#fff;font-size:12.5px;letter-spacing:2.5px;text-transform:uppercase;margin-bottom:18px;font-weight:500}
  footer ul{list-style:none}
  footer li{margin-bottom:9px}
  footer a:hover{color:#fff}
  .foot-brand img{height:44px;margin-bottom:16px;filter:brightness(0) invert(1)}
  .foot-brand p{max-width:300px;color:#a49d95;font-size:13.5px}
  .foot-bottom{border-top:1px solid #2a2a2a;padding:22px 0;display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;font-size:12.5px;color:#8a847d}
  .socials{display:flex;gap:16px}

  @media(max-width:920px){
    .hero-grid{grid-template-columns:1fr;min-height:0}
    .hero-media{height:340px;order:-1;position:relative}
    .hero-media img{position:relative}
    .hero-copy{padding:46px 24px}
    .hero h1{font-size:36px}
    .trio,.prod-row{grid-template-columns:repeat(2,1fr)}
    .coll-grid{grid-template-columns:repeat(2,1fr)}
    .tiers{grid-template-columns:1fr}
    .foot-grid{grid-template-columns:1fr 1fr}
    .nav-list{gap:20px;overflow-x:auto}
    .mega{display:none!important}
  }
</style>
<style id="m-nav-css">
  .hamburger{display:none}
  .m-drawer{position:fixed;inset:0;z-index:200;visibility:hidden;opacity:0;transition:opacity .25s,visibility .25s}
  .m-drawer.open{visibility:visible;opacity:1}
  .m-back{position:absolute;inset:0;background:rgba(17,17,17,.5)}
  .m-panel{position:absolute;top:0;left:0;height:100%;width:min(87vw,370px);background:#fff;overflow-y:auto;-webkit-overflow-scrolling:touch;transform:translateX(-100%);transition:transform .3s ease;padding-bottom:40px}
  .m-drawer.open .m-panel{transform:none}
  .m-head{display:flex;align-items:center;justify-content:space-between;padding:18px 20px 14px;border-bottom:1px solid var(--line);position:sticky;top:0;background:#fff}
  .m-head span{font-family:var(--serif);font-size:20px}
  .m-close{background:none;border:0;font-size:28px;line-height:1;cursor:pointer;color:var(--ink)}
  .m-grp{border-bottom:1px solid var(--line)}
  .m-grp>a,.m-grp>button{display:flex;width:100%;justify-content:space-between;align-items:center;gap:10px;padding:15px 20px;font-family:var(--sans);font-size:13.5px;letter-spacing:1.4px;text-transform:uppercase;background:none;border:0;color:var(--ink);cursor:pointer;text-align:left}
  .m-grp>a.sale{color:var(--red)}
  .m-caret{font-size:10px;color:var(--grey);transition:transform .2s}
  .m-grp.on .m-caret{transform:rotate(180deg)}
  .m-sub{display:none;padding:2px 20px 14px;background:var(--cream)}
  .m-grp.on .m-sub{display:block}
  .m-sub a{display:block;padding:9px 4px;font-size:13.5px;color:var(--grey);text-transform:none;letter-spacing:.3px}
  .m-sub a:active,.m-sub a:hover{color:var(--ink)}
  @media(max-width:920px){
    .hamburger{display:block;background:none;border:0;font-size:24px;line-height:1;cursor:pointer;color:var(--ink);padding:2px 6px}
    nav.main{display:none}
    .h-search{display:none!important}
    .icons a:not(:last-child){display:none}
    .header-inner{padding:13px 16px}
    .logo img{height:34px}
    .section{padding:52px 0}
    .banner{padding:64px 20px}
  }
</style>
<style>
  .shop-bar{display:flex;justify-content:space-between;align-items:center;gap:20px;flex-wrap:wrap;border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:14px 0}
  .filters{display:flex;gap:8px;flex-wrap:wrap}
  .fbtn{border:1px solid var(--line);background:#fff;padding:8px 16px;font-family:var(--sans);font-size:12px;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;font-weight:300}
  .fbtn:hover{border-color:var(--ink)}
  .fbtn.on{background:var(--ink);color:#fff;border-color:var(--ink)}
  .fbtn.sale-f{color:var(--red);border-color:var(--red)}
  .fbtn.sale-f.on{background:var(--red);color:#fff}
  .fbtn small{color:inherit;opacity:.55;margin-left:4px}
  #sort{padding:9px 12px;border:1px solid var(--line);font-family:var(--sans);font-size:13px;background:#fff;outline:none}
  .tag.sale{background:var(--red)}
  .tag.out{background:#8a847d}
  .was{color:var(--grey);text-decoration:line-through;font-weight:300;font-size:13px;margin-left:8px}
  .card-info .tags{display:flex;flex-wrap:wrap;gap:5px;margin-top:9px}
  .card-info .tags span{font-size:10px;letter-spacing:.5px;text-transform:uppercase;color:var(--grey);border:1px solid var(--line);border-radius:2px;padding:2px 7px;line-height:1.6}
</style>
<style>
