# Copy this file to .env.local and fill in your Supabase values
# Get these from: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# The base URL where your app is hosted (no trailing slash)
# Used to generate QR code URLs that point back to the right place
NEXT_PUBLIC_APP_URL=https://repticube.app
