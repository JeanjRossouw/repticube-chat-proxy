              },
              "blocks": {}
            },
            "story_heading": {
              "type": "text",
              "name": "Heading",
              "settings": {
                "text": "<h2>Hearth &amp; Hound</h2>",
                "width": "fit-content",
                "type_preset": "h2",
                "font": "var(--font-heading--family)",
                "color": "var(--color-foreground-heading)"
              },
              "blocks": {}
            },
            "story_text": {
              "type": "text",
              "name": "Story",
              "settings": {
                "text": "<p>The hearth has always been the warmest place in the house — and every hound knows it. We bring Huntlea’s decades of South African craftsmanship into homes like yours: beds sewn to last, covers that zip off and wash clean, and fillings that hold their comfort season after season.</p><p>Because a dog doesn’t just sleep on a bed. They claim it, they trust it, and they come home to it — the same way you do.</p>",
                "width": "fit-content",
                "max_width": "narrow",
                "type_preset": "paragraph",
                "font": "var(--font-body--family)",
                "color": "var(--color-foreground)"
              },
              "blocks": {}
            },
            "story_cta": {
              "type": "button",
              "name": "Button",
              "settings": {
                "label": "Explore the ranges",
                "link": "shopify://collections",
                "open_in_new_tab": false,
                "style_class": "button-secondary",
                "width": "fit-content",
                "width_mobile": "fit-content"
              },
              "blocks": {}
            }
          },
          "block_order": [
            "story_eyebrow",
            "story_heading",
            "story_text",
            "story_cta"
          ]
        }
      },
      "name": "Brand story",
      "settings": {
        "media_position": "left",
        "section_width": "page-width",
        "extend_media": false,
        "color_scheme": "scheme-2",
        "padding-block-start": 0,
